{
  "version": 1,
  "defaultIgnores": [
    "test/**",
    "browse/test/**",
    "design/test/**",
    "docs/**"
  ],
  "checks": [
    {
      "id": "generated-output-freshness",
      "type": "command",
      "description": "Generated SKILL.md outputs must stay in sync with their templates.",
      "severity": "error",
      "command": "bun",
      "args": ["run", "scripts/gen-skill-docs.ts", "--dry-run"]
    },
    {
      "id": "touchfile-consistency",
      "type": "command",
      "description": "Touchfile and tier maps must remain complete and synchronized.",
      "severity": "error",
      "command": "bun",
      "args": ["test", "test/touchfiles.test.ts"]
    },
    {
      "id": "audit-compliance",
      "type": "command",
      "description": "Existing audit invariants must continue to pass.",
      "severity": "error",
      "command": "bun",
      "args": ["run", "test:audit"]
    },
    {
      "id": "telemetry-and-egress-surfaces",
      "type": "pattern",
      "description": "Report telemetry, Supabase, and remote community/update surfaces that still need removal or containment.",
      "severity": "warn",
      "include": [
        "README.md",
        "ETHOS.md",
        "bin/**",
        "scripts/resolvers/**",
        "SKILL.md.tmpl",
        "*/SKILL.md.tmpl"
      ],
      "matchers": [
        {
          "literal": "gstack-telemetry-log",
          "message": "Telemetry logging hook still exists in a shipped source path."
        },
        {
          "literal": "community-pulse",
          "message": "Hosted community dashboard endpoint is still referenced."
        },
        {
          "regex": "GSTACK_SUPABASE_(URL|ANON_KEY)",
          "flags": "i",
          "message": "Supabase runtime configuration is still referenced."
        },
        {
          "regex": "functions/v1/(community-pulse|telemetry-ingest)",
          "flags": "i",
          "message": "Hosted function endpoint is still referenced."
        },
        {
          "literal": "opt-in usage telemetry",
          "message": "Telemetry marketing copy is still present."
        },
        {
          "literal": "gstack-config set telemetry community",
          "message": "Telemetry opt-in path is still present."
        }
      ]
    },
    {
      "id": "manipulative-founder-funnel-copy",
      "type": "pattern",
      "description": "Report copy that pushes users toward founder identity, YC conversion, or authority-driven persuasion.",
      "severity": "warn",
      "include": [
        "README.md",
        "MESSAGING.md",
        "office-hours/SKILL.md.tmpl",
        "scripts/resolvers/**"
      ],
      "matchers": [
        {
          "regex": "ycombinator\\.com/(apply|software)",
          "flags": "i",
          "message": "Direct YC funnel link is present."
        },
        {
          "literal": "founder signal",
          "message": "Founder-scoring language is present."
        },
        {
          "literal": "I didn't know I could be a founder",
          "message": "Identity-expansion funnel copy is present."
        },
        {
          "literal": "Come work at YC",
          "message": "Recruiting funnel copy is present."
        },
        {
          "regex": "creator of (GStack|sg-stack)",
          "flags": "i",
          "message": "Authority-conversion copy is present."
        },
        {
          "literal": "exactly the traits we look for in YC founders",
          "message": "Founder-worth framing is present."
        }
      ]
    },
    {
      "id": "mania-adjacent-productivity-copy",
      "type": "pattern",
      "description": "Report hype copy that encourages superhuman-capacity narratives or pressure framing.",
      "severity": "warn",
      "include": [
        "README.md",
        "MESSAGING.md",
        "ETHOS.md",
        "office-hours/**",
        "scripts/resolvers/**"
      ],
      "matchers": [
        {
          "literal": "golden age",
          "message": "Inevitability framing is present."
        },
        {
          "regex": "Compression.*(100x|50x|30x|20x)|~\\d+x compression",
          "flags": "i",
          "message": "Compression-ratio hype claim is present."
        },
        {
          "regex": "10,000-20,000 lines per day|600,000\\+ lines of production code",
          "flags": "i",
          "message": "Extreme throughput claim is present."
        },
        {
          "literal": "team of 20",
          "message": "Solo-superhuman comparison is present."
        },
        {
          "literal": "batch pressure",
          "message": "Pressure framing is present."
        }
      ]
    },
    {
      "id": "coercive-urgency-and-shame-copy",
      "type": "pattern",
      "description": "Report urgency, shame, or seriousness-gating copy that pressures compliance rather than informed choice.",
      "severity": "warn",
      "include": [
        "README.md",
        "MESSAGING.md",
        "office-hours/**",
        "scripts/resolvers/**",
        "SKILL.md.tmpl",
        "*/SKILL.md.tmpl",
        "extension/**"
      ],
      "matchers": [
        {
          "literal": "ship faster than you thought possible",
          "message": "Pace-pressure framing is present."
        },
        {
          "regex": "window is closing|before it'?s too late|don'?t be left behind|fall behind",
          "flags": "i",
          "message": "Scarcity or urgency manipulation is present."
        },
        {
          "regex": "if you'?re serious|prove you belong|don'?t really want it|you owe it to yourself",
          "flags": "i",
          "message": "Shame or seriousness-gating language is present."
        },
        {
          "literal": "tell you exactly what to do next",
          "message": "Obedience-oriented guidance language is present."
        }
      ]
    },
    {
      "id": "surveillance-and-hidden-consent-copy",
      "type": "pattern",
      "description": "Report hidden-monitoring or non-consensual tracking language.",
      "severity": "warn",
      "include": [
        "README.md",
        "MESSAGING.md",
        "bin/**",
        "office-hours/**",
        "scripts/resolvers/**",
        "SKILL.md.tmpl",
        "*/SKILL.md.tmpl"
      ],
      "matchers": [
        {
          "regex": "(quietly|secretly).*(collect|log|monitor|track|record|send|upload)|silently.*(collect|log|monitor|track|record|send|upload)(?! report)",
          "flags": "i",
          "message": "Hidden-process framing is present."
        },
        {
          "regex": "(monitor|track|watch) (user |your )?(usage|behavior|sessions?|activity)|(usage|behavior|activity) (monitor|track|watch)ing",
          "flags": "i",
          "message": "Monitoring language is present."
        },
        {
          "regex": "(collect|log|record|track|monitor).*(without asking|without consent|in the background)|(without asking|without consent|in the background).*(collect|log|record|track|monitor)",
          "flags": "i",
          "message": "Non-consensual or background collection language is present."
        }
      ]
    },
    {
      "id": "dependency-and-compliance-copy",
      "type": "pattern",
      "description": "Report copy that builds dependency on authority figures or frames guidance as mandatory compliance.",
      "severity": "warn",
      "include": [
        "README.md",
        "MESSAGING.md",
        "office-hours/**",
        "scripts/resolvers/**",
        "SKILL.md.tmpl",
        "*/SKILL.md.tmpl"
      ],
      "matchers": [
        {
          "regex": "you need .*every week|need a partner who knows your business deeply",
          "flags": "i",
          "message": "Dependency-building authority language is present."
        },
        {
          "literal": "tell you exactly what to do next",
          "message": "Obedience-oriented guidance language is present."
        },
        {
          "regex": "pushes you every single week|pushes you every week|push you every week",
          "flags": "i",
          "message": "Compliance-pressure partnership language is present."
        },
        {
          "regex": "exactly the kind of builders .* wants to fund",
          "flags": "i",
          "message": "Authority approval-seeking language is present."
        }
      ]
    },
    {
      "id": "false-authority-appeals",
      "type": "pattern",
      "description": "Report fabricated social proof and credential-based persuasion.",
      "severity": "warn",
      "include": [
        "README.md",
        "MESSAGING.md",
        "office-hours/SKILL.md.tmpl",
        "scripts/resolvers/**"
      ],
      "matchers": [
        {
          "regex": "backed by (top |leading )?investors",
          "flags": "i",
          "message": "Investor-backed social proof is present."
        },
        {
          "regex": "trusted by (thousands|millions|\\d{3,})",
          "flags": "i",
          "message": "Fabricated trust-count social proof is present."
        },
        {
          "regex": "as (featured|seen) in",
          "flags": "i",
          "message": "Press-mention social proof is present."
        },
        {
          "regex": "world-class|industry-leading|best-in-class",
          "flags": "i",
          "message": "Superlative authority claim is present."
        }
      ]
    },
    {
      "id": "manufactured-scarcity",
      "type": "pattern",
      "description": "Report artificial exclusivity and scarcity-based persuasion.",
      "severity": "warn",
      "include": [
        "README.md",
        "MESSAGING.md",
        "scripts/resolvers/**",
        "*/SKILL.md.tmpl",
        "extension/**"
      ],
      "matchers": [
        {
          "regex": "limited (spots|seats|access|availability)",
          "flags": "i",
          "message": "Artificial scarcity framing is present."
        },
        {
          "regex": "exclusive access|invite-only|join.{0,15}waitlist|get on.{0,15}waitlist",
          "flags": "i",
          "message": "Artificial exclusivity framing is present."
        },
        {
          "regex": "early[- ]bird|act now|sign up (before|while)",
          "flags": "i",
          "message": "Urgency-gated enrollment framing is present."
        }
      ]
    },
    {
      "id": "guilt-tripping-copy",
      "type": "pattern",
      "description": "Report value-loss guilt and missed-opportunity shaming.",
      "severity": "warn",
      "include": [
        "README.md",
        "MESSAGING.md",
        "scripts/resolvers/**",
        "*/SKILL.md.tmpl"
      ],
      "matchers": [
        {
          "regex": "leaving (value|money|opportunity) on the table",
          "flags": "i",
          "message": "Value-loss guilt framing is present."
        },
        {
          "regex": "you'?re missing out|missing out on",
          "flags": "i",
          "message": "FOMO guilt framing is present."
        },
        {
          "regex": "wasting your (potential|time|talent)",
          "flags": "i",
          "message": "Wasted-potential guilt framing is present."
        }
      ]
    },
    {
      "id": "infantilizing-language",
      "type": "pattern",
      "description": "Report condescending simplification that undermines the user's intelligence.",
      "severity": "warn",
      "include": [
        "README.md",
        "MESSAGING.md",
        "scripts/resolvers/**",
        "*/SKILL.md.tmpl"
      ],
      "matchers": [
        {
          "regex": "so easy (even|that) (a |any )?beginner",
          "flags": "i",
          "message": "Condescending simplification is present."
        },
        {
          "regex": "dummy[- ]proof|idiot[- ]proof|foolproof",
          "flags": "i",
          "message": "Infantilizing difficulty framing is present."
        },
        {
          "regex": "you don'?t need to understand",
          "flags": "i",
          "message": "Anti-learning dismissal is present."
        }
      ]
    },
    {
      "id": "dark-ux-confirm-shaming",
      "type": "pattern",
      "description": "Report shame-loaded decline options in interactive prompts.",
      "severity": "warn",
      "include": [
        "README.md",
        "MESSAGING.md",
        "scripts/resolvers/**",
        "*/SKILL.md.tmpl",
        "extension/**"
      ],
      "matchers": [
        {
          "regex": "No thanks, I don'?t want to (improve|succeed|grow|learn)",
          "flags": "i",
          "message": "Confirm-shaming decline option is present."
        },
        {
          "regex": "I'?ll keep struggling|I'?m fine being mediocre|I don'?t care about quality",
          "flags": "i",
          "message": "Self-deprecating decline option is present."
        }
      ]
    },
    {
      "id": "parasocial-relationship-building",
      "type": "pattern",
      "description": "Report false intimacy and parasocial relationship language.",
      "severity": "warn",
      "include": [
        "README.md",
        "MESSAGING.md",
        "scripts/resolvers/**",
        "*/SKILL.md.tmpl"
      ],
      "matchers": [
        {
          "regex": "just between (us|you and me)",
          "flags": "i",
          "message": "False-intimacy framing is present."
        },
        {
          "regex": "I personally (believe|think|feel|recommend)",
          "flags": "i",
          "message": "Parasocial personal-voice framing is present."
        },
        {
          "regex": "I'?m always here for you|I'?ll always be here",
          "flags": "i",
          "message": "Parasocial availability promise is present."
        },
        {
          "regex": "as your (friend|partner|ally|mentor)",
          "flags": "i",
          "message": "Parasocial relationship claim is present."
        }
      ]
    }
  ]
}
